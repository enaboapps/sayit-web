---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Capability from '../components/Capability.astro';
import PullQuote from '../components/PullQuote.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://app.sayitaac.com';
const githubUrl =
  import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com/enaboapps/sayit-web';

const title = 'SayIt! — AAC software for people who need help being heard';
const description =
  'AAC software with phrase boards, AI-assisted writing, and text-to-speech. Built so the person being supported is the person being heard.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    {/* 1. Hero */}
    <section class="bg-paper pt-24 pb-16 md:pt-32 md:pb-20">
      <div class="mx-auto max-w-[var(--container-prose)] px-6 md:px-12 lg:px-16">
        <h1
          class="max-w-[10ch] text-[clamp(4rem,11vw,8.5rem)] font-extrabold leading-[0.92] tracking-[-0.03em] text-ink"
        >
          SayIt!
        </h1>
        <p
          class="mt-8 text-2xl font-medium leading-tight text-ink md:text-4xl"
        >
          AAC software for people who need help being heard — and the people
          helping them.
        </p>
        <p class="mt-6 text-[1.0625rem] leading-[1.65] text-muted md:text-lg">
          Phrase boards, AI-assisted writing, and text-to-speech, designed so
          the person communicating stays in charge of what gets said.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href={appUrl}
            class="inline-flex items-center justify-center rounded-md bg-accent px-5 py-3 text-base font-semibold text-paper hover:bg-accent-strong"
          >
            Open the app
          </a>
          <a
            href={githubUrl}
            class="inline-flex items-center justify-center rounded-md border border-line bg-surface px-5 py-3 text-base font-semibold text-ink hover:border-accent hover:text-accent-strong"
          >
            Read the source
          </a>
        </div>
      </div>
    </section>

    {/* 2. Pull-quote (thesis) */}
    <PullQuote>
      Communication tools should stay close to the person using them. Every
      feature in SayIt! answers to that.
    </PullQuote>

    {/* 3. Audience split */}
    <Section id="audience" eyebrow="Who it's for" width="wide">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        Two audiences, one app.
      </h2>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <div>
          <h3 class="text-lg font-semibold text-ink md:text-xl">
            For communicators.
          </h3>
          <p
            class="mt-3 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
          >
            For people whose speech is unreliable, intermittent, or absent.
            SayIt! is a board you own, a composer you control, and a voice that
            speaks only when you say so.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-ink md:text-xl">
            For caregivers, teachers, and SLPs.
          </h3>
          <p
            class="mt-3 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
          >
            A separate caregiver role with its own dashboard. Manage clients,
            prepare boards, set view-or-edit access — without ever speaking for
            the communicator.
          </p>
        </div>
      </div>
    </Section>

    {/* 4. Principles */}
    <Section id="principles" eyebrow="Principles" width="prose">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        Four rules we don't bend.
      </h2>
      <ol class="mt-2 space-y-8">
        <li class="grid grid-cols-[2.5rem_1fr] gap-4">
          <span class="text-base font-bold text-accent-strong">01</span>
          <div>
            <p class="text-lg font-semibold text-ink md:text-xl">
              The communicator decides what gets spoken.
            </p>
            <p
              class="mt-2 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
            >
              AI suggests. The person sends. Nothing autoplays, nothing speaks
              without a tap.
            </p>
          </div>
        </li>
        <li class="grid grid-cols-[2.5rem_1fr] gap-4">
          <span class="text-base font-bold text-accent-strong">02</span>
          <div>
            <p class="text-lg font-semibold text-ink md:text-xl">
              Caregivers prepare; they don't perform.
            </p>
            <p
              class="mt-2 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
            >
              Caregiver tools shape boards and routines. They don't put words in
              anyone's mouth.
            </p>
          </div>
        </li>
        <li class="grid grid-cols-[2.5rem_1fr] gap-4">
          <span class="text-base font-bold text-accent-strong">03</span>
          <div>
            <p class="text-lg font-semibold text-ink md:text-xl">
              Plain text first, premium when chosen.
            </p>
            <p
              class="mt-2 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
            >
              Browser TTS, typed messages, and cached boards work without a
              subscription. Premium voices and AI assistance are opt-in.
            </p>
          </div>
        </li>
        <li class="grid grid-cols-[2.5rem_1fr] gap-4">
          <span class="text-base font-bold text-accent-strong">04</span>
          <div>
            <p class="text-lg font-semibold text-ink md:text-xl">
              Public source, reserved brand.
            </p>
            <p
              class="mt-2 text-[1.0625rem] leading-[1.65] text-muted md:text-lg"
            >
              The code is AGPL-3.0. The SayIt! name and marks are reserved by
              Enabo Apps.
            </p>
          </div>
        </li>
      </ol>
    </Section>

    {/* 5. Capabilities ledger */}
    <Section id="capabilities" eyebrow="Capabilities" width="wide">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        What's in the app today.
      </h2>
      <div>
        <Capability n="01" name="Phrase boards" state="shipping">
          Reusable tile-based boards for daily routines, broken into navigable
          sets.
        </Capability>
        <Capability n="02" name="Tile types" state="recent">
          Phrase tiles, navigation tiles, and recorded-audio tiles. Recorded
          audio shipped in v3.16.4.
        </Capability>
        <Capability n="03" name="Composer" state="shipping">
          Tabs, multiple drafts, undo and redo. Built for the rhythm of
          constructing a real message.
        </Capability>
        <Capability n="04" name="Fix Text" state="shipping">
          Turns rough phrasing into clearer messages. The communicator sees the
          suggestion and decides.
        </Capability>
        <Capability n="05" name="Reply Suggestions" state="shipping">
          Hints for what to say next, never sent automatically.
        </Capability>
        <Capability n="06" name="Text-to-speech" state="shipping">
          Browser voices by default. ElevenLabs, Azure, and Gemini available
          with a configured premium key.
        </Capability>
        <Capability n="07" name="Live Typing" state="shipping">
          Share a typing session in real time over Convex when the receiver
          can't read a screen up close.
        </Capability>
        <Capability n="08" name="Symbol search" state="shipping">
          Symbol picker backed by a licensed symbol set.
        </Capability>
        <Capability n="09" name="Caregiver workflows" state="shipping">
          Distinct caregiver role with managed clients and per-board view or
          edit access.
        </Capability>
      </div>
    </Section>

    {/* 6. What works offline */}
    <Section id="offline" eyebrow="Offline" width="prose">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        Honest about what works without a connection.
      </h2>
      <p class="text-xl leading-[1.55] text-ink md:text-2xl">
        SayIt! installs as a PWA. Some things keep working when the network
        drops. Others can't — and we'd rather say so than let you discover it
        mid-conversation.
      </p>
      <table class="mt-10 w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-line">
            <th
              class="py-3 pr-4 text-xs font-bold uppercase tracking-[0.12em] text-accent-strong"
            >
              Works offline
            </th>
            <th
              class="py-3 pl-4 text-xs font-bold uppercase tracking-[0.12em] text-accent-strong"
            >
              Needs a connection
            </th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-line">
            <td
              class="py-4 pr-4 text-[1.0625rem] leading-[1.5] text-ink md:text-lg"
            >
              Typing in the composer
            </td>
            <td
              class="py-4 pl-4 text-[1.0625rem] leading-[1.5] text-muted md:text-lg"
            >
              AI assistance (Fix Text, Reply Suggestions)
            </td>
          </tr>
          <tr class="border-b border-line">
            <td
              class="py-4 pr-4 text-[1.0625rem] leading-[1.5] text-ink md:text-lg"
            >
              Reading cached boards
            </td>
            <td
              class="py-4 pl-4 text-[1.0625rem] leading-[1.5] text-muted md:text-lg"
            >
              Premium TTS (ElevenLabs, Azure, Gemini)
            </td>
          </tr>
          <tr class="border-b border-line">
            <td
              class="py-4 pr-4 text-[1.0625rem] leading-[1.5] text-ink md:text-lg"
            >
              Browser text-to-speech
            </td>
            <td
              class="py-4 pl-4 text-[1.0625rem] leading-[1.5] text-muted md:text-lg"
            >
              Live Typing sessions
            </td>
          </tr>
          <tr class="border-b border-line">
            <td
              class="py-4 pr-4 text-[1.0625rem] leading-[1.5] text-ink md:text-lg"
            >
              Speaking saved phrases
            </td>
            <td
              class="py-4 pl-4 text-[1.0625rem] leading-[1.5] text-muted md:text-lg"
            >
              Convex sync, sign-in, billing
            </td>
          </tr>
        </tbody>
      </table>
    </Section>

    {/* 7. Privacy & data */}
    <Section id="privacy" eyebrow="Privacy and data" width="prose">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        Where your data goes, named out loud.
      </h2>
      <p class="text-[1.0625rem] leading-[1.65] text-muted md:text-lg">
        User data lives in Convex. Authentication is handled by Clerk. Billing
        runs on Stripe via Clerk — SayIt! never sees your card.
      </p>
      <p class="mt-6 text-[1.0625rem] leading-[1.65] text-muted md:text-lg">
        Premium AI calls go to OpenRouter. Premium voices run on ElevenLabs,
        Azure, or Gemini, only when configured and only when invoked. Symbols
        come from a licensed symbol set.
      </p>
      <p class="mt-6 text-[1.0625rem] leading-[1.65] text-muted md:text-lg">
        The full privacy policy lives at the app subdomain.
      </p>
      <p class="mt-8">
        <a
          href={`${appUrl}/privacy`}
          class="font-semibold text-accent-strong underline-offset-4 hover:text-accent hover:underline"
        >
          Read the privacy policy →
        </a>
      </p>
    </Section>

    {/* 8. Open source */}
    <Section id="open-source" eyebrow="Open source" width="wide">
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-ink md:text-5xl"
      >
        AGPL-3.0. Brand reserved.
      </h2>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <p class="text-[1.0625rem] leading-[1.65] text-muted md:text-lg">
          The code is public under AGPL-3.0. Run it, read it, fork it. The
          SayIt! name, logo, and domain are not part of that license — they
          belong to Enabo Apps.
        </p>
        <dl
          class="space-y-3 border-l-2 border-line pl-6 text-[1.0625rem] leading-[1.55] md:text-lg"
        >
          <div>
            <dt class="text-xs font-bold uppercase tracking-[0.12em] text-accent-strong">
              License
            </dt>
            <dd class="text-ink">AGPL-3.0</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase tracking-[0.12em] text-accent-strong">
              Source
            </dt>
            <dd>
              <a
                href={githubUrl}
                class="text-ink underline-offset-4 hover:text-accent-strong hover:underline"
              >
                github.com/enaboapps/sayit-web
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase tracking-[0.12em] text-accent-strong">
              Brand
            </dt>
            <dd class="text-ink">Reserved by Enabo Apps</dd>
          </div>
        </dl>
      </div>
    </Section>

    {/* 9. Pull-quote (closing) */}
    <PullQuote>
      Built so the person being supported is the person being heard.
    </PullQuote>

    {/* 10. CTA close */}
    <Section tone="ink" width="prose" divider={false}>
      <h2
        slot="heading"
        class="text-3xl font-bold leading-[1.05] tracking-[-0.02em] text-paper md:text-5xl"
      >
        Open SayIt! and start communicating.
      </h2>
      <p class="text-xl leading-[1.55] text-paper/85 md:text-2xl">
        Use it in a browser, install it as a PWA, or read the source on GitHub.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href={appUrl}
          class="inline-flex items-center justify-center rounded-md bg-paper px-5 py-3 text-base font-semibold text-ink hover:bg-soft"
        >
          Open the app
        </a>
        <a
          href={`${appUrl}/support`}
          class="inline-flex items-center justify-center rounded-md border border-paper/30 px-5 py-3 text-base font-semibold text-paper hover:border-paper hover:bg-paper/5"
        >
          Get support
        </a>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
