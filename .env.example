# Copy this file to .env.local for local development.
# Values prefixed with NEXT_PUBLIC_ are client-visible and must not contain secrets.
# Server-only keys must never be committed to the repository.
# Production secrets are managed through GitHub, Vercel, Convex, and provider secret stores.
# Contributors can run many tests without all production keys, but cloud-backed auth,
# database, AI, and premium TTS flows require configured service accounts.

NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWT_ISSUER_DOMAIN=

OPENROUTER_API_KEY=

ELEVENLABS_API_KEY=

GEMINI_API_KEY=

AZURE_SUBSCRIPTION_KEY=
AZURE_REGION=

CONVEX_DEPLOY_KEY=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_WEB_PROJECT_ID=
VERCEL_LANDING_PROJECT_ID=

PUBLIC_APP_URL=https://app.sayitaac.com
PUBLIC_GITHUB_URL=https://github.com/enaboapps/sayit-web
